{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quick Authenticator",
  "version": "1.0.0",
  "identifier": "com.quick.authenticator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3020",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Quick Authenticator",
        "width": 420,
        "height": 720,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libappindicator3-1"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
