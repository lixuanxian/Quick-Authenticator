{
  "name": "quick-authenticator",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "vite",
    "dev:web": "vite --mode web",
    "build": "vite build",
    "build:web": "vite build --mode web",
    "preview": "vite preview",
    "preview:web": "vite preview --mode web --outDir dist-web",
    "dev:desktop": "tauri dev",
    "build:desktop": "tauri build",
    "build:desktop:local": "tauri build --no-bundle",
    "init:android": "tauri android init && npm run icons:android",
    "dev:android": "tauri android dev",
    "build:android": "tauri android build --apk --target aarch64",
    "icons:android": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-store": "^2",
    "html5-qrcode": "^2.3.8",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "vite": "^6"
  }
}
